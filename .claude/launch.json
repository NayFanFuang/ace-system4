{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dta-html",
      "runtimeExecutable": "python",
      "runtimeArgs": [
        "-m",
        "http.server",
        "8899",
        "--directory",
        "frontend"
      ],
      "port": 8899
    },
    {
      "name": "ace-vite",
      "runtimeExecutable": "docker",
      "runtimeArgs": [
        "logs",
        "-f",
        "ace-system-frontend"
      ],
      "port": 5173,
      "autoPort": false
    },
    {
      "name": "ace-vite-host",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--",
        "--port",
        "5199",
        "--strictPort",
        "--host"
      ],
      "cwd": "frontend",
      "port": 5199,
      "autoPort": false
    }
  ]
}
